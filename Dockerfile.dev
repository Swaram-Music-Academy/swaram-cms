FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    jq \
    postgresql-client \
    curl \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install deps first (layer cache)
COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted at runtime, but this ensures
# node_modules exists in the image for faster starts.
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
