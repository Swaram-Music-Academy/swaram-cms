{
  "name": "Swaram CMS Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },

  "forwardPorts": [5173, 54321, 54323],
  "portsAttributes": {
    "5173":  { "label": "Vite Dev Server" },
    "54321": { "label": "Supabase API" },
    "54323": { "label": "Supabase Studio" }
  },

  "postCreateCommand": "npm ci && npm install -g supabase@latest",
  "postStartCommand": "bash scripts/dev-up.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },

  "remoteUser": "node"
}
